#Adult Income
def load_adult_tensors():
    dataset = load_dataset("scikit-learn/adult-census-income")
    df      = dataset["train"].to_pandas()
    df      = df.apply(lambda col: col.str.strip() if col.dtype == "object" else col)
    df["income"] = (df["income"] == ">50K").astype(int)
    df      = df.replace("?", __import__("numpy").nan).dropna()
    cat_cols = df.select_dtypes(include="object").columns.tolist()
    for col in cat_cols:
        df[col] = __import__("sklearn.preprocessing", fromlist=["LabelEncoder"]).LabelEncoder().fit_transform(df[col])
    X = df.drop("income", axis=1).values.astype(__import__("numpy").float32)
    y = df["income"].values.astype(__import__("numpy").int64)
    X = StandardScaler().fit_transform(X)
    split = int(0.8 * len(X))
    train = TensorDataset(torch.tensor(X[:split]), torch.tensor(y[:split]))
    test  = TensorDataset(torch.tensor(X[split:]), torch.tensor(y[split:]))
    return train, test, X.shape[1]

adult_train, adult_test, input_dim = load_adult_tensors()

def load_fmnist_model(path):
    model = MNISTModel().to(device)
    state_dict = torch.load(path, map_location=device)
    state_dict = {k.replace("_module.", ""): v for k, v in state_dict.items()}
    model.load_state_dict(state_dict)
    return model

def load_adult_model(path):
    model = AdultModel(input_dim=input_dim).to(device)
    state_dict = torch.load(path, map_location=device)
    state_dict = {k.replace("_module.", ""): v for k, v in state_dict.items()}
    model.load_state_dict(state_dict)
    return model

