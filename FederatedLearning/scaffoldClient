import sys, os
sys.path.append(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

import torch
import torch.nn as nn
import torch.optim as optim
import numpy as np
import flwr as fl
from models.mnist_model import MNISTModel
from fl.data_utils import load_mnist, get_client_loader

_train_dataset, _test_dataset = load_mnist()

class SCAFFOLDClient(fl.client.NumPyClient):

    def __init__(self, client_id, partition, device):
        self.client_id = client_id
        self.device    = device
        self.loader    = get_client_loader(_train_dataset, partition)
        self.model     = MNISTModel().to(device)
        self.criterion = nn.CrossEntropyLoss()

        #Local and global control variates, initialised to zeros
        self.c_local  = [torch.zeros_like(p) for p in self.model.parameters()]
        self.c_global = [torch.zeros_like(p) for p in self.model.parameters()]

    def get_parameters(self, config):
        return [p.detach().cpu().numpy() for p in self.model.parameters()]

    def set_parameters(self, parameters):
        for p, new_p in zip(self.model.parameters(), parameters):
            p.data = torch.tensor(new_p).to(self.device)

    def fit(self, parameters, config):
        self.set_parameters(parameters)

        #reduced from 0.01 for stability
        lr           = 0.005  
        local_epochs = config.get("local_epochs", 1)
        K            = local_epochs * len(self.loader)

        x_global = [p.clone().detach() for p in self.model.parameters()]

        optimizer = optim.SGD(self.model.parameters(), lr=lr, momentum=0.9)
        self.model.train()

        for _ in range(local_epochs):
            for data, target in self.loader:
                data, target = data.to(self.device), target.to(self.device)
                optimizer.zero_grad()
                loss = self.criterion(self.model(data), target)
                loss.backward()

                #SCAFFOLD correction: adjust gradient by (c_local - c_global)
                for p, c_l, c_g in zip(self.model.parameters(),
                                        self.c_local, self.c_global):
                    if p.grad is not None:
                        p.grad.data -= (c_l - c_g)

                #Gradient clipping for stability
                torch.nn.utils.clip_grad_norm_(self.model.parameters(), max_norm=1.0)
                optimizer.step()

        with torch.no_grad():
            for i, (c_l, c_g, x_g, p) in enumerate(zip(
                    self.c_local, self.c_global,
                    x_global, self.model.parameters())):
                self.c_local[i] = c_l - c_g + (x_g - p.data) / (K * lr)

        return self.get_parameters(config={}), len(self.loader.dataset), {}

    def evaluate(self, parameters, config):
        self.set_parameters(parameters)
        self.model.eval()

        correct, total, loss_sum = 0, 0, 0.0
        test_loader = get_client_loader(
            _test_dataset, list(range(len(_test_dataset)))
        )
        with torch.no_grad():
            for data, target in test_loader:
                data, target = data.to(self.device), target.to(self.device)
                output    = self.model(data)
                loss_sum += self.criterion(output, target).item()
                correct  += output.argmax(1).eq(target).sum().item()
                total    += len(target)

        return loss_sum / total, total, {"accuracy": correct / total}
